<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#16171a"
    android:padding="14dp">

    <!-- Glowing emerald green border accent on the left (ImageView) -->
    <ImageView
        android:id="@+id/widget_accent_bar"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:background="#10b981"
        android:contentDescription="Accent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_toEndOf="@id/widget_accent_bar"
        android:layout_marginStart="14dp"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <!-- Illustration Sprout Emoji -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌱"
            android:textSize="28sp"
            android:layout_marginBottom="4dp" />

        <!-- Motivational Saying -->
        <TextView
            android:id="@+id/widget_saying"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Focus on the 1% today. Your daily rituals define you."
            android:textColor="#ffffff"
            android:textSize="11.5sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.1"
            android:ellipsize="end"
            android:maxLines="2" />

        <!-- Tap to Update Streak callout -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ Tap to update streak"
            android:textColor="#10b981"
            android:textSize="9.5sp"
            android:textStyle="bold"
            android:layout_marginTop="6dp"
            android:letterSpacing="0.04" />
    </LinearLayout>

</RelativeLayout>
